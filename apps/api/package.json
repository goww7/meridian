{
  "name": "@meridian/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:unit": "vitest run --dir src",
    "test:integration": "vitest run --dir tests",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:migrate": "tsx src/infra/db/migrate.ts",
    "db:seed": "tsx src/infra/db/seed.ts",
    "db:uat-seed": "tsx src/infra/db/uat-seed.ts",
    "test:uat": "vitest run --dir tests/uat --reporter=verbose",
    "uat": "tsx src/infra/db/uat-seed.ts && vitest run --dir tests/uat --reporter=verbose",
    "graph:init": "tsx src/graph/init.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/websocket": "^11.0.0",
    "@google/genai": "^1.47.0",
    "@meridian/policy-dsl": "workspace:*",
    "@meridian/shared": "workspace:*",
    "argon2": "^0.41.0",
    "bullmq": "^5.30.0",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.4.0",
    "openai": "^6.33.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
