{
  "name": "meridian",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:unit": "turbo test:unit",
    "test:integration": "turbo test:integration",
    "test:e2e": "pnpm --filter=@meridian/web exec playwright test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:migrate": "pnpm --filter=@meridian/api db:migrate",
    "db:seed": "pnpm --filter=@meridian/api db:seed",
    "db:uat-seed": "pnpm --filter=@meridian/api db:uat-seed",
    "test:uat": "pnpm --filter=@meridian/api test:uat",
    "uat": "pnpm --filter=@meridian/api uat",
    "graph:init": "pnpm --filter=@meridian/api graph:init",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
